# Copy to .env in the repo root (gitignored) for local runs and for the "Harness" debug config in .vscode/launch.json
FEATUREFLOW_SERVER_KEY=
FEATUREFLOW_BASE_URL=

# SDK `debug` logs to stderr (PollingClient, Client, etc.) when this namespace is enabled
DEBUG=featureflow-node-sdk
