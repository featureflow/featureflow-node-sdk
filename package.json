{
  "name": "featureflow-node-sdk",
  "version": "0.6.19",
  "description": "Featureflow sdk for Node",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "engines": {
    "node": ">4.0.0"
  },
  "packageManager": "yarn@4.4.1",
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "babel src -d dist --source-maps && tsc",
    "watch": "babel --watch src -d dist --source-maps",
    "prepublish": "yarn build",
    "test": "node_modules/.bin/cucumber-js --require-module babel-core/register -r features/step_definitions -r features/support --format=json:cucumber-report.json -t \"not @ignore and not @integration and not @builder-defers-implicit-attributes\" testbed/gherkin && node_modules/.bin/cucumber-junit < cucumber-report.json > output_JUnit.xml",
    "ci-test": "node_modules/.bin/cucumber-js --require-module babel-core/register -r features/step_definitions -r features/support --format=json:cucumber-report.json -t \"not @ignore and not @integration and not @builder-defers-implicit-attributes\" testbed/gherkin && node_modules/.bin/cucumber-junit < cucumber-report.json > ~/junit.xml",
    "test:integration": "node_modules/.bin/cucumber-js --require-module babel-core/register -r features/step_definitions -r features/support -t \"@integration\" features/integration.feature",
    "preexample:server": "yarn build",
    "example:server": "node examples/harness/server.js"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/featureflow/featureflow-node-sdk.git"
  },
  "author": "Featureflow <featureflow@featureflow.io>",
  "license": "Apache-2.0",
  "bugs": {
    "url": "https://github.com/featureflow/featureflow-node-sdk/issues"
  },
  "homepage": "https://github.com/featureflow/featureflow-node-sdk#readme",
  "dependencies": {
    "big-integer": "^1.6.17",
    "debug": "^2.6.2",
    "request": "^2.88.0",
    "sha1-hex": "^1.0.0",
    "typescript": "^4.8.2"
  },
  "devDependencies": {
    "babel-cli": "^6.26.0",
    "babel-core": "^6.26.0",
    "babel-plugin-transform-flow-strip-types": "^6.22.0",
    "babel-plugin-transform-object-rest-spread": "^6.23.0",
    "babel-preset-es2015": "^6.24.0",
    "babel-preset-stage-2": "^6.22.0",
    "chai": "^3.5.0",
    "cucumber": "^4.2.1",
    "cucumber-junit": "^1.7.1",
    "express": "^4.21.0",
    "moment": "^2.18.1"
  }
}
